# -----------------------------
# Python & System
# -----------------------------
__pycache__/
*.pyc
*.pyo
venv/
.venv/
.env
.DS_Store
.vscode/
.idea/

# -----------------------------
# DATA & SAMPLES (Governance)
# -----------------------------
# Exclude the specific samples folder
data/samples/
# Exclude raw input data but keep the folder structure
data/input/*

# -----------------------------
# GENERATED ARTEFACTS
# -----------------------------
*.csv
*.xlsx
*.xls
*.xml

# Intentional, version-controlled config-review artefacts (committed on purpose).
!output/config_review/
!output/config_review/*.csv

# Generated JSON (but NOT configs / schemas)
run_manifest.json
*lineage*.json
*out*.json

# Phase 8E — dev-only live Anthropic smoke artefacts (may contain provider
# responses; never commit). The directory is kept via artifacts/.gitkeep.
artifacts/*
!artifacts/.gitkeep

# -----------------------------
# OUTPUT DIRECTORIES
# -----------------------------
out/
out_validation/
logs/
*.log

# -----------------------------
# SECRETS (defensive)
# -----------------------------
*secret*
*key*
*cred*

# -----------------------------
# ALLOW CONFIG / SCHEMA FILES
# -----------------------------
!**/*.yaml
!**/*.yml
!**/*schema.json
!pyproject.toml

# -----------------------------
# Exception Management DB
# -----------------------------
*.db

# -----------------------------
# Compressed Archives
# -----------------------------
*.zip
*.7z
*.rar
*.tar.gz
# Demo fixtures
!demo/*.csv

# Trakt Onboarding Agent v2 generated packs
onboarding_output/
!synthetic_onboarding_pack/*.csv
# Onboarding Agent Phase 1 — domain-based synthetic packs (committed fixtures)
!synthetic_onboarding_pack_domain_based/scenario_a_combined/*.csv
!synthetic_onboarding_pack_domain_based/scenario_b_split/*.csv
# Onboarding Agent — committed test fixtures (synthetic, no real data)
!tests/fixtures/*.csv
# MI runtime — committed synthetic multi-artefact fixtures (subdirectories)
!tests/fixtures/**/*.csv
portfolio_test/
