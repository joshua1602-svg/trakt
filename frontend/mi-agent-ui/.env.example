# MI Agent front-end configuration.
#
# Leave unset to run in demo mode (MockAgentClient). Set the API URL to bind the
# UI to the live MI Agent API (mi_agent_api / FastAPI).
#
# VITE_AGENT_API_URL=http://localhost:8000
# VITE_AGENT_MODE=mock   # force mock even when an API URL is set
#
# Codespaces / forwarded ports (no CORS): the dev server proxies /mi + /health to
# the API, so run the UI with a relative base URL to stay same-origin:
#   VITE_AGENT_API_URL=/ npm run dev
# (optional) point the proxy at a non-default API host:
#   VITE_PROXY_TARGET=http://localhost:8000
