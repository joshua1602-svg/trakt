# Keep the container build context lean. Runtime PACKAGES used by the MI API are
# intentionally NOT excluded: mi_agent_api, mi_agent, snapshot, analytics_lib,
# engine, apps, config. (snapshot/ is a Python package — snapshot.model /
# snapshot.store — NOT a scratch dir; do not exclude it.)
.git
.github
.gitignore
**/__pycache__
**/*.pyc
.venv
venv
.localblob

# Frontend (React) — not part of the API image
frontend
node_modules

# Generated / scratch OUTPUT dirs (regenerated at runtime; none are packages)
out
out_validation
output
onboarding_output
artifacts

# Tests + docs + diligence (not needed at runtime)
**/tests
docs
due_diligence
*.zip
